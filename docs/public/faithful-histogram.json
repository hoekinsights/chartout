{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": { "url": "/faithful.json" },
  "width": 400,
  "height": 200,
  "mark": "bar",
  "encoding": {
    "x": {
      "field": "eruptions",
      "type": "quantitative",
      "bin": { "maxbins": 20 },
      "title": "Eruption duration (min)"
    },
    "y": {
      "aggregate": "count",
      "title": "Count"
    },
    "color": { "value": "steelblue" }
  }
}
